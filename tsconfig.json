{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "lib": ["ESNext"],
    "types": ["node"],
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "main.ts",
    "storage.ts",
    "models.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}