{
  "name": "cwmp-sim",
  "version": "0.1.2",
  "description": "TypeScript CWMP/TR-069 CPE simulator for testing ACS sessions, SOAP RPCs, diagnostics, transfers, and Connection Requests.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "cwmp-sim": "dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "gen:html": "node gen-html.mjs",
    "predev": "npm run gen:html",
    "dev": "node --import tsx --env-file=.env ./main.ts",
    "prebuild": "npm run gen:html",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file=.env ./dist/main.js",
    "precheck": "npm run gen:html",
    "check": "tsc --noEmit",
    "pretest": "npm run gen:html",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run check && npm run test",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "release:dry": "npm publish --dry-run"
  },
  "keywords": [
    "cwmp",
    "tr-069",
    "tr069",
    "tr-098",
    "tr-181",
    "acs",
    "cpe",
    "simulator",
    "genieacs",
    "soap",
    "xml",
    "broadband",
    "typescript"
  ],
  "author": "Luiz Softov <fernandosoftov@gmail.com>",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/softov/cwmp-sim.git"
  },
  "bugs": {
    "url": "https://github.com/softov/cwmp-sim/issues"
  },
  "homepage": "https://github.com/softov/cwmp-sim#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  }
}
