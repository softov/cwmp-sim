# Copy to .env and adjust. The dev/start scripts load this via --env-file=.env

# ACS the simulated CPE will call into (Inform / SOAP session)
ACS_URL=http://localhost:7547/acs
ACS_USER=usertest
ACS_PASS=passtest

# Connection Request server the CPE exposes to the ACS
CONN_SSL=true
CONN_ADDR=0.0.0.0
CONN_PORT=7547
CONN_USER=usertest
CONN_PASS=passtest

# Simulated device identity
DEVICE_INDEX=1
DEVICE_ROOT=InternetGatewayDevice
DEVICE_SERIAL=SIM{i:08}            # → SIM00000001
DEVICE_OUI=C0FFEE                  # literal vendor OUI (hex)
DEVICE_MAC=C0:FF:EE:00:00:{i:02x}  # → 00:E0:FC:00:00:01
DEVICE_PRODUCT_CLASS=Simulator
#DEVICE_CSV=models/data_model_test.csv
#DEVICE_JSON=models/data_model_test.json
